{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "YANK",
  "version": "0.1.0",
  "identifier": "com.mockelsoft.yank",
  "build": {
    "frontendDist": "../dist/yank/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "pnpm ng serve",
    "beforeBuildCommand": "pnpm ng build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YANK",
        "width": 480,
        "height": 680,
        "minWidth": 320,
        "minHeight": 200,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Mockelsoft",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": ["http://localhost:8787/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIwMUM3MkRDQkREQTg0QUQKUldTdGhOcTkzSEljSU9nbWxKTEJHOWZzZitDeS9XQmxOMFVkUlg3bFd0WVRoR0JSUllLY29yU3IK",
      "dangerousInsecureTransportProtocol": true
    }
  }
}
