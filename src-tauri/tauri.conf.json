{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clipboard Manager",
  "version": "0.1.0",
  "identifier": "com.clipboardmanager.app",
  "build": {
    "frontendDist": "../dist/clipboard-manager/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "pnpm ng serve",
    "beforeBuildCommand": "pnpm ng build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clipboard Manager",
        "width": 420,
        "height": 520,
        "minWidth": 320,
        "minHeight": 200,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
